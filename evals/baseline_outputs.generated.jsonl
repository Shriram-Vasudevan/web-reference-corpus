           category: \"IT\"\n              },\n              {\n                title: \"Event Management\",\n                description: \"Sync calendar events with team notifications and task creation\",\n                apps: [\"Google Calendar\", \"Asana\", \"Slack\"],\n                category: \"Operations\"\n              }\n            ].map((template, index) => (\n              <div key={index} className=\"bg-white border border-gray-200 rounded-lg p-6 hover:shadow-lg transition-shadow\">\n                <div className=\"flex items-center justify-between mb-4\">\n                  <span className=\"bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded\">\n                    {template.category}\n                  </span>\n                  <button className=\"text-gray-400 hover:text-gray-600\">\n                    <svg className=\"w-5 h-5\" fill=\"currentColor\" viewBox=\"0 0 20 20\">\n                      <path d=\"M10 6a2 2 0 110-4 2 2 0 010 4zM10 12a2 2 0 110-4 2 2 0 010 4zM10 18a2 2 0 110-4 2 2 0 010 4z\" />\n                    </svg>\n                  </button>\n                </div>\n                <h3 className=\"text-lg font-semibold text-gray-900 mb-2\">{template.title}</h3>\n                <p className=\"text-gray-600 mb-4\">{template.description}</p>\n                <div className=\"flex items-center justify-between\">\n                  <div className=\"flex -space-x-2\">\n                    {template.apps.map((app, appIndex) => (\n                      <div key={appIndex} className=\"w-6 h-6 bg-gray-300 rounded-full border-2 border-white\"></div>\n                    ))}\n                  </div>\n                  <button className=\"text-blue-600 text-sm font-medium hover:text-blue-700\">\n                    Use Template\n                  </button>\n                </div>\n              </div>\n            ))}\n          </div>\n        </div>\n      </section>\n\n      {/* Pricing Preview */}\n      <section class